# =============================================================================
# Конфигурация Remnawave Grace Access
# =============================================================================

# Выбор backend-а:
# - remnawave: работать напрямую с Remnawave API через remnawave SDK.
# - bot: работать через Bedolaga Bot API.
API_BACKEND=remnawave


# =============================================================================
# Remnawave backend
# Обязателен только при API_BACKEND=remnawave
# =============================================================================

# Базовый URL Remnawave API.
# Обычно это URL панели с суффиксом /api.
REMNAWAVE_API_BASE=https://remnawave.example.com/api

# Токен Remnawave API.
REMNAWAVE_API_TOKEN=put-remnawave-token-here

# Опциональный Caddy token, если он нужен в вашей установке Remnawave.
# Оставьте пустым, если не используется.
REMNAWAVE_CADDY_TOKEN=

# Отключить проверку TLS-сертификата для Remnawave API.
# В production лучше держать false, если вы не используете самоподписанные сертификаты осознанно.
REMNAWAVE_SSL_IGNORE=false


# =============================================================================
# Bedolaga Bot API backend
# Обязателен только при API_BACKEND=bot
# =============================================================================

# Базовый URL Bedolaga Bot API.
# Пример: https://api.example.com
BOT_API_BASE=https://api.example.com

# API key для Bedolaga Bot API.
# Worker отправляет его в заголовке X-API-Key.
BOT_API_KEY=put-bot-api-key-here

# Отключить проверку TLS-сертификата для Bot API.
# В production лучше держать false, если вы не используете самоподписанные сертификаты осознанно.
BOT_API_SSL_IGNORE=false


# =============================================================================
# Целевые статусы и squads
# =============================================================================

# Статусы, которые нужно обрабатывать.
# В Remnawave статусы обычно uppercase, в Bot API могут быть lowercase.
# Worker нормализует значения внутри, поэтому здесь можно оставить uppercase.
TARGET_STATUSES=EXPIRED,LIMITED

# Squad для истекших подписок/пользователей.
# Используется при статусе EXPIRED / expired.
TARGET_EXPIRED_SQUAD_UUID=e9534880-836d-41bc-9dc4-a453056ad5d1

# Squad для ограниченных подписок/пользователей.
# Используется при статусе LIMITED / limited.
TARGET_LIMITED_SQUAD_UUID=06e88dc4-6b6e-4db0-8de0-28c68ac12025

# Опциональный общий fallback squad для всех статусов.
# Если TARGET_EXPIRED_SQUAD_UUID или TARGET_LIMITED_SQUAD_UUID пустой,
# worker использует TARGET_SQUAD_UUID для этого статуса.
# TARGET_SQUAD_UUID=e9534880-836d-41bc-9dc4-a453056ad5d1


# =============================================================================
# Лимиты временного доступа
# =============================================================================

# Количество дней, которое выдается на каждом цикле grace access.
# Должно быть больше 0.
EXTEND_DAYS=3

# Лимит трафика для временного доступа, в байтах.
# Значение ниже - 1 GiB.
#
# Remnawave backend:
# - выставляет traffic_limit_bytes ровно в это значение.
#
# Bot API backend:
# - конвертирует это значение в целые GiB с округлением вверх;
# - 1073741824 -> 1 GB;
# - 1500000000 -> 2 GB;
# - 0 отключает вызов добавления трафика через Bot API.
TRAFFIC_LIMIT_BYTES=1073741824


# =============================================================================
# Цикл сканирования и пагинация
# =============================================================================

# Задержка между циклами сканирования, в секундах.
# Должна быть больше 0.
SCAN_INTERVAL_SECONDS=60

# Размер страницы для list-запросов.
# Remnawave backend: 1..500.
# Bot API backend: 1..200.
#
# Для Remnawave обычно используйте 500:
PAGE_SIZE=500
#
# Для Bot API используйте 200:
# PAGE_SIZE=200


# =============================================================================
# Хранилище состояния
# =============================================================================

# Путь к SQLite базе состояния worker-а.
# Этот файл защищает от бесконтрольной повторной выдачи grace access.
STATE_DB_PATH=./data/state.sqlite3


# =============================================================================
# Безопасность и диагностика
# =============================================================================

# Режим проверки без реальных изменений.
# true:
# - сканирует и логирует подходящих пользователей/подписки;
# - не вызывает изменяющие API endpoints;
# - не записывает успешные продления в SQLite.
#
# false:
# - выполняет реальные обновления.
#
# Рекомендуемый первый запуск:
# 1. запустить с DRY_RUN=true;
# 2. проверить логи;
# 3. переключить на DRY_RUN=false только после проверки.
DRY_RUN=true

# Уровень логирования Python.
# Частые значения: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO


# =============================================================================
# Пользователь Docker runtime
# =============================================================================

# UID/GID, которые docker-entrypoint.sh использует для Python-процесса и папки SQLite.
# На Linux значения можно посмотреть командой: id
PUID=1000
PGID=1000
