# =============================================================================
# Remnawave Grace Access configuration
# =============================================================================

# Backend selector:
# - remnawave: work directly with Remnawave API through remnawave SDK.
# - bot: work through Bedolaga Bot API.
API_BACKEND=remnawave


# =============================================================================
# Remnawave backend
# Required only when API_BACKEND=remnawave
# =============================================================================

# Remnawave API base URL.
# Usually this is your panel URL with /api suffix.
REMNAWAVE_API_BASE=https://remnawave.example.com/api

# Remnawave API token.
REMNAWAVE_API_TOKEN=put-remnawave-token-here

# Optional Caddy token if your Remnawave setup requires it.
# Leave empty if not used.
REMNAWAVE_CADDY_TOKEN=

# Disable TLS certificate verification for Remnawave API.
# Keep false in production unless you deliberately use self-signed certs.
REMNAWAVE_SSL_IGNORE=false


# =============================================================================
# Bedolaga Bot API backend
# Required only when API_BACKEND=bot
# =============================================================================

# Bedolaga Bot API base URL.
# Example: https://api.example.com
BOT_API_BASE=https://api.example.com

# Bedolaga Bot API key.
# The worker sends it in the X-API-Key header.
BOT_API_KEY=put-bot-api-key-here

# Disable TLS certificate verification for Bot API.
# Keep false in production unless you deliberately use self-signed certs.
BOT_API_SSL_IGNORE=false


# =============================================================================
# Target statuses and squads
# =============================================================================

# Statuses to process.
# Remnawave statuses are uppercase, Bot API statuses may be lowercase;
# the worker normalizes them internally, so this value can stay uppercase.
TARGET_STATUSES=EXPIRED,LIMITED

# Squad for expired subscriptions/users.
# Used when status is EXPIRED / expired.
TARGET_EXPIRED_SQUAD_UUID=e9534880-836d-41bc-9dc4-a453056ad5d1

# Squad for limited subscriptions/users.
# Used when status is LIMITED / limited.
TARGET_LIMITED_SQUAD_UUID=06e88dc4-6b6e-4db0-8de0-28c68ac12025

# Optional single fallback squad for all statuses.
# If TARGET_EXPIRED_SQUAD_UUID or TARGET_LIMITED_SQUAD_UUID is empty,
# the worker uses TARGET_SQUAD_UUID for that status.
# TARGET_SQUAD_UUID=e9534880-836d-41bc-9dc4-a453056ad5d1


# =============================================================================
# Grace access limits
# =============================================================================

# Number of days to grant on each grace access cycle.
# Must be greater than 0.
EXTEND_DAYS=3

# Traffic limit for temporary access, in bytes.
# Default below is 1 GiB.
#
# Remnawave backend:
# - sets traffic_limit_bytes to this exact value.
#
# Bot API backend:
# - converts this value to whole GiB with rounding up;
# - 1073741824 -> 1 GB;
# - 1500000000 -> 2 GB;
# - 0 disables the Bot API traffic add call.
TRAFFIC_LIMIT_BYTES=1073741824


# =============================================================================
# Scan loop and pagination
# =============================================================================

# Delay between scan cycles, in seconds.
# Must be greater than 0.
SCAN_INTERVAL_SECONDS=60

# Page size for list requests.
# Remnawave backend: 1..500.
# Bot API backend: 1..200.
#
# Use 500 for Remnawave:
PAGE_SIZE=500
#
# Use 200 for Bot API:
# PAGE_SIZE=200


# =============================================================================
# State storage
# =============================================================================

# SQLite database path for worker state.
# This file prevents uncontrolled repeated grace access.
STATE_DB_PATH=./data/state.sqlite3


# =============================================================================
# Safety and diagnostics
# =============================================================================

# Dry-run mode.
# true:
# - scans and logs matching users/subscriptions;
# - does not call mutating API endpoints;
# - does not record successful extensions in SQLite.
#
# false:
# - performs real updates.
#
# Recommended for the first launch:
# 1. start with DRY_RUN=true;
# 2. inspect logs;
# 3. switch to DRY_RUN=false only after verification.
DRY_RUN=true

# Python logging level.
# Common values: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO


# =============================================================================
# Docker runtime user
# =============================================================================

# UID/GID used by docker-entrypoint.sh for the Python process and SQLite folder.
# On Linux you can check your values with: id
PUID=1000
PGID=1000
